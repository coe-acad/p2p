# @capacitor-firebase/app 8.x declares a peerOptional on firebase@^12; our
# project pins firebase@^11. The dep is optional, and the plugin only uses
# the JS Firebase SDK integration on paths our app doesn't hit (native
# Android uses the Firebase Android SDK via google-services.json; web
# short-circuits before reaching the plugin at all). Ignoring the peer
# check lets npm install cleanly on both local and Vercel.
legacy-peer-deps=true
